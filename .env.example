# ─────────────────────────────────────────────
#  KAIRU — The Void Marshal · Environment Config
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────

# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Server port (defaults to 3000 if not set)
PORT=3000

# Node environment: development | production
NODE_ENV=development

# Allowed CORS origin (your domain in production, localhost in dev)
# Use * to allow all origins (not recommended for production)
ALLOWED_ORIGIN=http://localhost:3000

# Optional: Rate limit — max requests per minute per IP on /api/chat
RATE_LIMIT_PER_MINUTE=30
